# Copy this file to .env and fill in real values. Never commit .env to git.

# --- Anthropic (script generation) ---
# No key needed here if you're calling api.anthropic.com directly with your
# Anthropic account's API key — get it from console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# --- ElevenLabs (voiceover) ---
# Sign up at elevenlabs.io > Profile > API Keys
ELEVENLABS_API_KEY=
# Pick a voice at elevenlabs.io/voice-library, click it, copy the Voice ID
ELEVENLABS_VOICE_ID=

# --- Pexels (stock background footage — free, commercial license, no attribution required) ---
# Sign up at pexels.com/api > Get Started, generate an API key
PEXELS_API_KEY=

# --- YouTube Data API (upload) ---
# From Google Cloud Console > APIs & Services > Credentials (see SETUP.md)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8080/oauth2callback
# Generated once by running: npx tsx get-refresh-token.ts
YOUTUBE_REFRESH_TOKEN=
